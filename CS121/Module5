        /* Import new ArrayList named SpouseList2 from csv to hold second set of spouse names */
        ArrayList<String> spouseList2 = LabUtility.buildListFromCSV(csvFile,3);

        /* Create new ArrayList named finalSpouseList to combine data from both spouseLists */
        ArrayList<String> finalSpouseList = new ArrayList<String>();
        finalSpouseList.addAll(spouseList1);
        finalSpouseList.addAll(spouseList2);

        /* Import new ArrayList named occupationList from csv to hold the types of occupations */
        ArrayList<String> occupationList = LabUtility.buildListFromCSV(csvFile,4);

        /* Import new ArrayList named transporationList from csv to hold the types of transportation */
