 * After a certain number of years of marriage, they will recieve their dream job,
 * how they will get there, and where they will move to.
 * @author Amanda Halverson
 */

 public class MASHGame
 {
     public static void main(String[] args)
     {
        /* Declare new Scanner named myKbd to capture user responses */
        Scanner myKbd = new Scanner(System.in);

        /* Get name from user */
        String userName = LabUtility.getName(myKbd);

         /* Import new ArrayList named homeList from csv to hold the types of homes */
