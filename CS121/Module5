_________________________________LabUtility methods_________________________________________________________

import java.util.Random;
import java.util.Scanner;

/**
 * This code contains the methods to use to get user name, user chosen seed numbeer and print five
 * lottery numbers and a power pick.
 * 
 * @author Amanda Halverson
 */

public class LabUtility
{

    /**
     * Prompt the user to enter their name then use the provided Scanner object to read the entire
     * line of user input (including spaces) as a String and return this value to the caller.
     * 
     * @param kbd Scanner object bound to System.in
     * @return String containing name
     */

    public static String getName(Scanner kbd)
    {
        System.out.print("Please enter your name: ");
        String userName = kbd.nextLine();
        return userName;
    }

    /** Prompt the user to enter a seed value, then use the provided Scanner object to read the entire
     * line of user input as a String. Use the Long.parseLong() static method to convert the String
     * to a long value. If the user enters a value that cannot be parsed as a long value, display
     * an error message and prompt the user to enter the seed value again. Once a long value has been
     * successfully read, return this value to the caller.
     * 
     * @param kbd Scanner object bound to System.in
     * @return long value to be used as Random seed
     */

    public static long getSeed(Scanner kbd)
    {
        boolean needInput = true;
        long seedLong = 0;
                
        while (needInput) {
            System.out.print("Please enter a seed value: ");
            String seed = kbd.nextLine();
        
            try {
                seedLong = Long.parseLong(seed.trim());
                needInput = false;
            }
            catch (NumberFormatException e) {
                System.out.println("Error: Please enter only whole numbers\n");
            }
        }
        return seedLong;
    }    

    /** Use the provided Random object to generate five integer values in the range of 1-69 (inclusive)
     * followed by one number in the range of 1-26 (inclusive) for the power pick. Print the resulting
     * lottery ticket to the console using the following format pattern:
     * 
     * "%02d-%02d-%02d-%02d-%02d / %02d\n"
     * 
     * @param rnd Random object to use for ticket generation
     */

    public static void printTicket(Random rnd)
    {
        int number1 = rnd.nextInt(69) + 1;
        int number2 = rnd.nextInt(69) + 1;
        int number3 = rnd.nextInt(69) + 1;
        int number4 = rnd.nextInt(69) + 1;
        int number5 = rnd.nextInt(69) + 1;
        int pick = rnd.nextInt(26)+1;        
        
        System.out.print("Your quick pick is: ");
        System.out.printf("%02d-%02d-%02d-%02d-%02d / %02d\n", number1, number2, number3, number4, number5, pick);
    }
}

_____________________________Lab 1: HousingCrunch main (also uses LabUtility for methods)__________________________

import java.util.Scanner;
import java.util.ArrayList;
import java.util.Random;

/**
 * There is a housing crisis in Boise!! This code will ask the user for their name and a seed
 * value to use in a randomizer to give the user advice on what type of home they should purchase.
 * 
 * @author Amanda Halverson
 */

 public class HousingCrunch
 {
     public static void main(String[] args)
     {

        /* Declare new Scanner named myKbd to capture user responses */
        Scanner myKbd = new Scanner(System.in);

        /* Declare new ArrayList named homeList to hold the types of homes */
        ArrayList<String> homeList = new ArrayList<String>();

        /* Populate ArrayList with home types */
        homeList.add("mansion");
        homeList.add("apartment");
        homeList.add("shack");
        homeList.add("house");

        /* Get name from user */
        String userName = LabUtility.getName(myKbd);

        /* Get seed value from user */
        long userSeed = LabUtility.getSeed(myKbd);
        myKbd.close();

        /* Declare new Random variable named rand */
        Random rand = new Random(userSeed);        

        /* Print result using seed value in randomizer to determine what type of home to buy*/
        System.out.println("\nHello " + userName + ",");
        int answer = rand.nextInt(homeList.size());
        System.out.println("You should buy a " + (homeList.get(answer)) + ".");
    }
}

