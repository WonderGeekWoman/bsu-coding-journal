        int randSpouse = rand.nextInt(finalSpouseList.size());
        System.out.print("You will marry " + finalSpouseList.get(randSpouse));

        int randHome = rand.nextInt(homeList.size());
        System.out.println(" and live in a " + homeList.get(randHome) + ".");

