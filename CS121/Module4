import java.util.Scanner;

/**
 * Counts and prints the individual lower-case vowels and other characters in user-inputted string.
 * @author Amanda Halverson
 */

public class VowelCounter
{
    /**
     * Reads string from user and outputs as stated above.
     * @param args
     */

    public static void main (String[] args)
    {
        /* Declare variables */

        String userString;
        int aTotal = 0;
        int eTotal = 0;
        int iTotal = 0;
        int oTotal = 0;
        int uTotal = 0;
        int otherTotal = 0;

        Scanner kbd = new Scanner (System.in);

        /* Input processing */

        System.out.println("Enter a string of characters:");
        userString = kbd.nextLine();

        /* Nested Loop processing */

        for (int i = 0; i < userString.length(); i++)
        {
            switch (userString.charAt(i))
            {
                case 'a':
                    aTotal++;
                    break;
                case 'e':
                    eTotal++;
                    break;
                case 'i':
                    iTotal++;
                    break;
                case 'o':
                    oTotal++;
                    break;
                case 'u':
                    uTotal++;
                    break;
                default:
                    otherTotal++;
                    break;
            }
        }
        /* Output processing */

        System.out.println();
        System.out.println("Number of each lowercase vowel in the string:");
        System.out.println("a: " + aTotal);
        System.out.println("e: " + eTotal);
        System.out.println("i: " + iTotal);
        System.out.println("o: " + oTotal);
        System.out.println("u: " + uTotal);
        System.out.println("other characters: " + otherTotal);

        kbd.close();
    }
}


