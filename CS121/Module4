import java.util.Scanner;

/**
 * Takes a user-inputted year no earlier than 1582 and determines whether or not it is a leap year
 * @author Amanda Halverson
 */

public class LeapChecker
{
    /**
     * Reads year from user and outputs leap year or not.
     * @param args
     */
    
    public static void main (String[] args)
    {
        int userYear;

        Scanner kbd = new Scanner (System.in);

        /* Input processing */
         
        System.out.print("Enter a year: ");
        userYear = kbd.nextInt();
        
        /* Conditionals and Output processing */

        /* Exit immediately if input year is less than 1582, when Gregorian calendar was adopted */

        if (userYear < 1582) {
            System.out.println("ERROR: not valid in Gregorian calendar");
            System.exit(1);
        }

        /* Calculate if leap year and output result */

        else if (userYear % 4 == 0) {
            if ((userYear % 100 == 0) && !(userYear % 400 == 0)) {
                System.out.println(userYear + " is a not leap year");
            }
            else {
            System.out.println(userYear + " is a leap year");
            }
        }
        else {
            System.out.println(userYear + " is not a leap year");
        }

        kbd.close();
    }
}
