import java.util.Scanner;

/**
 * Sum all even numbers from 2 to user-inputted integer greater than or equal to 2, inclusive
 * @author Amanda Halverson
 */

public class EvenNumberSum {
    
    /**
     * Reads user input and outputs sum of even numbers from 2 up to input value
     * @param args
     */

    public static void main (String[] args) {

    Scanner kbd = new Scanner(System.in);

    int userInt;
    int i;
    int sumEvens = 0;

    /* Input processing */
    
    System.out.print("Enter a positive integer: ");
    userInt = kbd.nextInt();

    /* Exit if user int is less than 2 */
    if (userInt < 2) {
        System.out.println("Error: The value must be greater than two.");
        System.exit(1);
    }

    /* Output processing */

    else {
        for (i = 2; i < userInt + 1; i += 2) {
            sumEvens = sumEvens + i;
        }

        System.out.println ("The sum of the even integers from 2 to " + userInt + " is " + sumEvens);
    }

    kbd.close();

    }
}

