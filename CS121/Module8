import javax.swing.*;
import javax.swing.plaf.DimensionUIResource;
import java.awt.*;
import java.awt.event.*;
import java.text.DecimalFormat;

/**
 * SphereCalculator prompts the user for the radius of a sphere and calculates
 * its volume and surface area.
 * @author Amanda Halverson following video by Luke Hindman
 */

public class SphereCalculator extends JPanel
{
    /* Instance Variables */
    private JTextField radiusField;     // Holds radius input value
    private JButton calcButton;         // Triggers calculation
    private JLabel volumeLabel;         // Label for volume result
    private JLabel surfaceAreaLabel;    // Label for surface area result
    private JLabel radiusLabel;         // Label for radius prompt
    
    /* Constructor */
    public SphereCalculator()
    {
        /* Instantiate/initialize instance variables */
        this.radiusField = new JTextField(5);
        this.calcButton = new JButton("Calculate");
        this.volumeLabel = new JLabel("Volume: ");
        this.surfaceAreaLabel = new JLabel("Surface Area: ");
        this.radiusLabel = new JLabel("Radius:  ");

        /* Set up listeners */
        ActionListener myListener = new SphereListener();
        this.radiusField.addActionListener(myListener);
        this.calcButton.addActionListener(myListener);

        /* Radius entry subpanel */
        JPanel radiusEntrySubPanel = new JPanel();
        radiusEntrySubPanel.setLayout(new BoxLayout(radiusEntrySubPanel, BoxLayout.X_AXIS));
        radiusEntrySubPanel.add(radiusLabel);
        radiusEntrySubPanel.add(radiusField);

        /* Results subpanel */
        JPanel resultsSubPanel = new JPanel();
        resultsSubPanel.setLayout(new BoxLayout(resultsSubPanel, BoxLayout.Y_AXIS));
        resultsSubPanel.add(Box.createVerticalGlue());
        resultsSubPanel.add(volumeLabel);
        resultsSubPanel.add(surfaceAreaLabel);
        resultsSubPanel.add(Box.createVerticalGlue());
         
        /* Setup top-level panel */
        setPreferredSize(new DimensionUIResource(400,100));
        setLayout(new BorderLayout());
        add(radiusEntrySubPanel, BorderLayout.NORTH);
        add(this.calcButton, BorderLayout.EAST);
        add(resultsSubPanel, BorderLayout.CENTER);
    }

    /* Other Methods */
    /** Calculates surface area and volume of sphere with given radius, and updates labels
     * @param radius Radius of sphere
    */
    private void updateCalculation(double radius)
    {
        double sphereVolume = (4.0 / 3.0 * Math.PI * Math.pow(radius, 3));
        double sphereSurfaceArea = 4 * Math.PI * Math.pow(radius, 2);

        DecimalFormat myFormat = new DecimalFormat("#,###,###.####");

        volumeLabel.setText("Volume: " + myFormat.format(sphereVolume));
        surfaceAreaLabel.setText("Surface Area: " + myFormat.format(sphereSurfaceArea));
    }

    /* Button Listener */
    private class SphereListener implements ActionListener
    {
        @Override
        public void actionPerformed(ActionEvent e)
        {
            /* Get text from radiusField as String and store in userRadius variable */
            String userRadius = radiusField.getText();

            /* Error handling */
            try
            {
                /* Parse String into Double (if possible) and store in radius variable */
                double radius = Double.parseDouble(userRadius);

                /* Catch and reject negative numbers after parsing and don't calculate */
                if (radius < 0 )
                {
                    JOptionPane.showMessageDialog(null, "Please enter positive values only!");
                    radiusField.setText("");
                }
                else
                {
                    /* Pass in radius, do calculations, format, update information on labels */
                    updateCalculation(radius);
                }
            }
            catch (NumberFormatException err)
            {
                JOptionPane.showMessageDialog(null, "Please enter numbers only!");
                radiusField.setText("");
            }
        }
    }

    /* MAIN DRIVER */
    public static void main (String[] args)
    {
        JFrame myFrame = new JFrame("SphereCalculator...TADA!!");
        myFrame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);

        /* Add a panel to the frame */
        JPanel myPanel = new SphereCalculator();
        myFrame.getContentPane().add(myPanel);

        myFrame.pack();
        myFrame.setVisible(true);
    }
}

